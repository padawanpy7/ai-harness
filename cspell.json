    "@cspell/dict-es-es/cspell-ext.json"
  ],
  "ignorePaths": [
    "**/node_modules/**",
    "**/dist/**",
    "**/build/**",
    "**/bin/**",
    "**/obj/**",
    "*.svg",
    "*.lock",
    "package-lock.json",
    "*.min.*",
    ".git/**",
    "work/**",
    "*.json",
    "**/test-results/**",
    "**/playwright-report/**"
